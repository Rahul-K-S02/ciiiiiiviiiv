// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - trustScore: number (optional)
//   - createdAt: string (required)
//
// Collection: incidents
// Document ID: {incidentId}
// Fields:
//   - id: string (required)
//   - type: string (required, enum)
//   - description: string (required)
//   - location: map (required)
//     - latitude: number
//     - longitude: number
//     - address: string
//   - status: string (required, enum)
//   - priority: string (required, enum)
//   - reporterUid: string (required)
//   - reporterName: string (required)
//   - createdAt: string (required)
//   - eta: string (optional)
//   - imageUrl: string (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "04rahulks@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.displayName.size() < 100;
    }

    function isValidIncident(data) {
      return data.keys().hasAll(['type', 'description', 'location', 'status', 'priority', 'reporterUid', 'createdAt']) &&
             data.type in ['road_damage', 'electrical', 'water_supply', 'sanitation', 'other'] &&
             data.status in ['reported', 'verified', 'in_progress', 'resolved'] &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.description is string && data.description.size() < 2000 &&
             data.location is map &&
             data.location.latitude is number &&
             data.location.longitude is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIncident(request.resource.data) && 
                    request.resource.data.reporterUid == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.reporterUid == request.auth.uid && isValidIncident(request.resource.data)));
      allow delete: if isAdmin();
    }
  }
}
